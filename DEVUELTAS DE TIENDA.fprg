    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="CT, CB, CD" type="Integer" array="False" size=""/>
            <input variable="CT"/>
            <input variable="CB"/>
            <if expression="CT&gt;CB">
                <then>
                    <assign variable="CD" expression="CB-CT"/>
                </then>
                <else>
                    <output expression="&quot;NO ALCANZA&quot;" newline="True"/>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
