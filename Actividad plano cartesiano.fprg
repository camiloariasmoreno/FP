    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="x1, x2, y1, y2, distancia" type="Real" array="False" size=""/>
            <input variable="x1"/>
            <input variable="x2"/>
            <input variable="y1"/>
            <input variable="y2"/>
            <assign variable="distancia" expression="sqrt(((x2-x1)^2)+((y2-y1)^2))"/>
        </body>
    </function>
</flowgorithm>
