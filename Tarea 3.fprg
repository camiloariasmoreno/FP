    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="Metrocubico, Ancho, Alto, Precio, Total, Largo" type="Real" array="False" size=""/>
            <input variable="Precio"/>
            <input variable="Ancho"/>
            <input variable="Alto"/>
            <input variable="Largo"/>
            <assign variable="Metrocubico" expression="Ancho*Largo*Alto"/>
            <assign variable="Total" expression="Precio*Metrocubico"/>
            <output expression="Total" newline="True"/>
        </body>
    </function>
</flowgorithm>
